{
  "name": "@sprlab/microfront",
  "version": "0.0.4",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sprlab/microfront.git"
  },
  "description": "Vue micro frontend library using iframes with automatic resizing, messaging, and route synchronization (Vue 2 & 3)",
  "keywords": [
    "vue",
    "microfrontend",
    "iframe",
    "micro-frontend",
    "penpal"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./shell": {
      "import": "./dist/shell.js",
      "types": "./dist/shell/index.d.ts"
    },
    "./remote": {
      "import": "./dist/remote.js",
      "types": "./dist/remote/index.d.ts"
    }
  },
  "scripts": {
    "build": "LIB_ENTRY=remote vite build && LIB_ENTRY=shell vite build --emptyOutDir false && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "test": "vitest --run"
  },
  "dependencies": {
    "@open-iframe-resizer/core": "^2.3.1",
    "penpal": "^7.0.6"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^18.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-tsc": "^2.2.12"
  }
}
