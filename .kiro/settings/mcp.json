{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "chromium"
      ],
      "disabled": false,
      "autoApprove": [
        "browser_click",
        "browser_snapshot",
        "browser_navigate",
        "browser_console_messages",
        "browser_wait_for",
        "browser_navigate_back",
        "browser_evaluate"
      ]
    }
  }
}